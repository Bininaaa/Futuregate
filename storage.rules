rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{uid}/{allPaths=**} {
      allow read, write: if isSelf(uid);
    }

    match /companies/{uid}/{allPaths=**} {
      allow read, write: if isSelf(uid);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
