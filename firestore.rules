    match /opportunities/{opportunityId} {
      allow read: if signedIn() &&
          (isAdmin() ||
              resource.data.companyId == request.auth.uid ||
              (
                isStudent() &&
                exists(applicationPath(request.auth.uid + '_' + opportunityId))
              ) ||
              resource.data.status == 'open');

      allow create: if (isCompany() || isAdmin()) &&
          request.resource.data.keys().hasOnly([
            'id',
            'companyId',
            'companyName',
            'companyLogo',
            'title',
            'description',
            'type',
            'location',
            'requirements',
            'requirementItems',
            'originalLanguage',
            'status',
            'deadline',
            'createdBy',
            'createdByRole',
            'createdAt',
            'updatedAt',
            'salaryMin',
            'salaryMax',
            'salaryCurrency',
            'salaryPeriod',
            'compensationText',
            'employmentType',
            'workMode',
            'isPaid',
            'duration',
            'fundingAmount',
            'fundingCurrency',
            'fundingNote',
            'applicationDeadline',
            'earlyAccessRequested',
            'earlyAccessStatus',
            'requestedEarlyAccessAt'
          ]) &&
          request.resource.data.id == opportunityId &&
          request.resource.data.companyId == request.auth.uid &&
          request.resource.data.createdBy == request.auth.uid &&
          (
            (isAdmin() && request.resource.data.createdByRole == 'admin') ||
            (isCompany() && request.resource.data.createdByRole == 'company')
          ) &&
          isOpportunityType(request.resource.data.type) &&
          isOpportunityStatus(request.resource.data.status) &&
          hasValidOpportunityMetadata(request.resource.data) &&
          hasValidOpportunityEarlyAccessCreate(request.resource.data);

      allow update: if (
          (
            isAdmin() &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'isHidden',
              'updatedAt'
            ]) &&
            request.resource.data.id == resource.data.id &&
            request.resource.data.companyId == resource.data.companyId &&
            request.resource.data.createdAt == resource.data.createdAt
          ) ||
          (
            isAdmin() &&
            resource.data.companyId == request.auth.uid &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'companyName',
              'companyLogo',
              'title',
              'description',
              'type',
              'location',
              'requirements',
              'requirementItems',
              'originalLanguage',
              'status',
              'deadline',
              'createdBy',
              'createdByRole',
              'updatedAt',
              'salaryMin',
              'salaryMax',
              'salaryCurrency',
              'salaryPeriod',
              'compensationText',
              'employmentType',
              'workMode',
              'isPaid',
              'duration',
              'fundingAmount',
              'fundingCurrency',
              'fundingNote',
              'applicationDeadline'
            ]) &&
            request.resource.data.id == resource.data.id &&
            request.resource.data.companyId == resource.data.companyId &&
            request.resource.data.createdBy == request.auth.uid &&
            request.resource.data.createdByRole == 'admin' &&
            request.resource.data.createdAt == resource.data.createdAt &&
            isOpportunityType(request.resource.data.type) &&
            isOpportunityStatus(request.resource.data.status) &&
            hasValidOpportunityMetadata(request.resource.data)
          ) ||
          (
            isCompany() &&
            resource.data.companyId == request.auth.uid &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'companyName',
              'companyLogo',
              'title',
              'description',
              'type',
              'location',
              'requirements',
              'requirementItems',
              'originalLanguage',
              'status',
              'deadline',
              'createdBy',
              'createdByRole',
              'updatedAt',
              'salaryMin',
              'salaryMax',
              'salaryCurrency',
              'salaryPeriod',
              'compensationText',
              'employmentType',
              'workMode',
              'isPaid',
              'duration',
              'fundingAmount',
              'fundingCurrency',
              'fundingNote',
              'applicationDeadline',
              'earlyAccessRequested',
              'earlyAccessStatus',
              'requestedEarlyAccessAt'
            ]) &&
            request.resource.data.id == resource.data.id &&
            request.resource.data.companyId == resource.data.companyId &&
            request.resource.data.createdBy == request.auth.uid &&
            request.resource.data.createdByRole == 'company' &&
            request.resource.data.createdAt == resource.data.createdAt &&
            isOpportunityType(request.resource.data.type) &&
            isOpportunityStatus(request.resource.data.status) &&
            hasValidOpportunityMetadata(request.resource.data) &&
            hasValidCompanyOpportunityEarlyAccessUpdate()
          )
        );

      allow delete: if isAdmin() ||
          (isCompany() && resource.data.companyId == request.auth.uid);
    }

    match /applications/{applicationId} {
      allow read: if signedIn() &&
          (isAdmin() ||
              resource.data.studentId == request.auth.uid ||
              resource.data.companyId == request.auth.uid);

      allow create: if isStudent() &&
          request.resource.data.keys().hasOnly([
            'id',
            'studentId',
            'studentName',
            'opportunityId',
            'companyId',
            'cvId',
            'status',
            'appliedAt',
            'activityAt',
            'isPremiumAtApply',
            'priorityApplication',
            'subscriptionSnapshot'
          ]) &&
          request.resource.data.id == applicationId &&
          request.resource.data.studentId == request.auth.uid &&
          applicationId == request.auth.uid + '_' + request.resource.data.opportunityId &&
          request.resource.data.status == 'pending' &&
          (
            !request.resource.data.keys().hasAny(['activityAt']) ||
            request.resource.data.activityAt == request.time
          ) &&
          hasValidApplicationPrioritySnapshot(
            request.resource.data,
            request.auth.uid
          ) &&
          canStudentUseOpportunity(request.resource.data.opportunityId) &&
          get(opportunityPath(request.resource.data.opportunityId)).data.companyId ==
              request.resource.data.companyId &&
          (
            request.resource.data.cvId == '' ||
            (
              exists(cvPath(request.resource.data.cvId)) &&
              get(cvPath(request.resource.data.cvId)).data.studentId == request.auth.uid
            )
          );

      allow update: if (
          (
            isAdmin() &&
            resource.data.companyId == request.auth.uid &&
            resource.data.status != 'withdrawn' &&
            exists(opportunityPath(resource.data.opportunityId)) &&
            get(opportunityPath(resource.data.opportunityId)).data.companyId ==
                request.auth.uid &&
            get(opportunityPath(resource.data.opportunityId)).data.createdByRole ==
                'admin' &&
            request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'status'
            ]) &&
            request.resource.data.id == resource.data.id &&
            request.resource.data.studentId == resource.data.studentId &&
            request.resource.data.studentName == resource.data.studentName &&
            request.resource.data.opportunityId == resource.data.opportunityId &&
            request.resource.data.companyId == resource.data.companyId &&
            request.resource.data.cvId == resource.data.cvId &&
            request.resource.data.appliedAt == resource.data.appliedAt &&
            isApplicationStatus(request.resource.data.status)
          ) ||
          (
            isCompany() &&
            resource.data.companyId == request.auth.uid &&
            resource.data.status != 'withdrawn' &&
            request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'status'
            ]) &&
            request.resource.data.id == resource.data.id &&
            request.resource.data.studentId == resource.data.studentId &&
            request.resource.data.studentName == resource.data.studentName &&
            request.resource.data.opportunityId == resource.data.opportunityId &&
            request.resource.data.companyId == resource.data.companyId &&
            request.resource.data.cvId == resource.data.cvId &&
            request.resource.data.appliedAt == resource.data.appliedAt &&
            isApplicationStatus(request.resource.data.status)
          ) ||
          (
            isStudent() &&
            resource.data.studentId == request.auth.uid &&
            resource.data.status == 'pending' &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'status',
              'withdrawnAt',
              'activityAt',
              'hadWithdrawnBefore'
            ]) &&
            request.resource.data.id == resource.data.id &&
            request.resource.data.studentId == resource.data.studentId &&
            request.resource.data.studentName == resource.data.studentName &&
            request.resource.data.opportunityId == resource.data.opportunityId &&
            request.resource.data.companyId == resource.data.companyId &&
            request.resource.data.cvId == resource.data.cvId &&
            request.resource.data.appliedAt == resource.data.appliedAt &&
            request.resource.data.status == 'withdrawn' &&
            request.resource.data.withdrawnAt == request.time &&
            (
              !request.resource.data.keys().hasAny(['activityAt']) ||
              request.resource.data.activityAt == request.time
            ) &&
            (
              !request.resource.data.keys().hasAny(['hadWithdrawnBefore']) ||
              request.resource.data.hadWithdrawnBefore == true
            )
          ) ||
          (
            isStudent() &&
            resource.data.studentId == request.auth.uid &&
            resource.data.status == 'withdrawn' &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'studentName',
              'companyId',
              'cvId',
              'status',
              'appliedAt',
              'withdrawnAt',
              'activityAt',
              'hadWithdrawnBefore',
              'lastWithdrawnAt',
              'isPremiumAtApply',
              'priorityApplication',
              'subscriptionSnapshot'
            ]) &&
            request.resource.data.id == resource.data.id &&
            request.resource.data.studentId == resource.data.studentId &&
            request.resource.data.opportunityId == resource.data.opportunityId &&
            request.resource.data.status == 'pending' &&
            canStudentUseOpportunity(resource.data.opportunityId) &&
            get(opportunityPath(resource.data.opportunityId)).data.companyId ==
                request.resource.data.companyId &&
            hasValidApplicationPrioritySnapshot(
              request.resource.data,
              request.auth.uid
            ) &&
            (
              request.resource.data.cvId == '' ||
              (
                exists(cvPath(request.resource.data.cvId)) &&
                get(cvPath(request.resource.data.cvId)).data.studentId == request.auth.uid
              )
            ) &&
            request.resource.data.appliedAt == request.time &&
            (
              !request.resource.data.keys().hasAny(['activityAt']) ||
              request.resource.data.activityAt == request.time
            ) &&
            (
              !request.resource.data.keys().hasAny(['hadWithdrawnBefore']) ||
              request.resource.data.hadWithdrawnBefore == true
            ) &&
            (
              !request.resource.data.keys().hasAny(['lastWithdrawnAt']) ||
              request.resource.data.lastWithdrawnAt == resource.data.withdrawnAt
            ) &&
            !request.resource.data.keys().hasAny(['withdrawnAt'])
          )
        );

      allow delete: if isAdmin() ||
          (
            isStudent() &&
            resource.data.studentId == request.auth.uid &&
            resource.data.status == 'pending'
          );
    }

    match /cvs/{cvId} {
      allow read: if signedIn() &&
          (isAdmin() ||
              resource.data.studentId == request.auth.uid);

      allow create: if isStudent() &&
          request.resource.data.keys().hasOnly([
            'id',
            'studentId',
            'fullName',
            'email',
            'phone',
            'address',
            'summary',
            'education',
            'experience',
            'skills',
            'languages',
