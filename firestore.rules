            'uploadedCvFileType',
            'uploadedCvCreatedAt',
            'uploadedCvStorageProvider',
            'exportedPdfUrl',
            'exportedPdfPath',
            'createdAt',
            'updatedAt'
          ]) &&
          request.resource.data.id == cvId &&
          request.resource.data.studentId == request.auth.uid;

      allow update: if isAdmin() ||
          (
            isStudent() &&
            resource.data.studentId == request.auth.uid &&
            request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'fullName',
              'email',
              'phone',
              'address',
              'summary',
              'education',
              'experience',
              'skills',
              'languages',
              'sourceType',
              'templateId',
              'primaryCvMode',
              'uploadedCvUrl',
              'uploadedCvPath',
              'uploadedFileName',
              'uploadedCvObjectKey',
              'uploadedCvUserId',
              'uploadedCvBucketName',
              'uploadedCvMimeType',
              'uploadedCvSizeOriginal',
              'uploadedCvFileType',
              'uploadedCvCreatedAt',
              'uploadedCvStorageProvider',
              'exportedPdfUrl',
              'exportedPdfPath',
              'uploadedCvFileId',
