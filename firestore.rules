rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function currentUserExists() {
      return signedIn() && exists(userPath(request.auth.uid));
    }

    function isActiveUser() {
      return currentUserExists() &&
          get(userPath(request.auth.uid)).data.isActive == true;
    }

    function isStudent() {
      return isActiveUser() &&
          get(userPath(request.auth.uid)).data.role == 'student';
    }

    function isCompany() {
      return isActiveUser() &&
          get(userPath(request.auth.uid)).data.role == 'company';
    }

    function isAdmin() {
      return isActiveUser() &&
          get(userPath(request.auth.uid)).data.role == 'admin';
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function opportunityPath(opportunityId) {
      return /databases/$(database)/documents/opportunities/$(opportunityId);
    }

    function canStudentUseOpportunity(opportunityId) {
      return exists(opportunityPath(opportunityId)) &&
          get(opportunityPath(opportunityId)).data.status == 'open' &&
          get(opportunityPath(opportunityId)).data.get('isHidden', false) != true &&
          (
            !get(opportunityPath(opportunityId)).data.keys().hasAny(['applicationDeadline']) ||
            get(opportunityPath(opportunityId)).data.applicationDeadline == null ||
            !(get(opportunityPath(opportunityId)).data.applicationDeadline is timestamp) ||
            get(opportunityPath(opportunityId)).data.applicationDeadline >= request.time
          );
    }

    function projectIdeaPath(ideaId) {
      return /databases/$(database)/documents/projectIdeas/$(ideaId);
    }

    function applicationPath(applicationId) {
      return /databases/$(database)/documents/applications/$(applicationId);
    }

    function subscriptionPath(uid) {
      return /databases/$(database)/documents/subscriptions/$(uid);
    }

    function cvPath(cvId) {
      return /databases/$(database)/documents/cvs/$(cvId);
    }

    function trainingPath(trainingId) {
      return /databases/$(database)/documents/trainings/$(trainingId);
    }

    function scholarshipPath(scholarshipId) {
      return /databases/$(database)/documents/scholarships/$(scholarshipId);
    }

    function conversationPath(conversationId) {
      return /databases/$(database)/documents/conversations/$(conversationId);
    }

    function isOpportunityType(value) {
      return value == 'job' ||
          value == 'internship' ||
          value == 'sponsoring';
    }

    function isOpportunityStatus(value) {
      return value == 'open' || value == 'closed';
    }

    function isEarlyAccessStatus(value) {
      return value == 'none' ||
          value == 'pending' ||
          value == 'approved' ||
          value == 'rejected' ||
          value == 'expired';
    }

    function isNullableString(value) {
      return value == null || value == '' || value is string;
    }

    function isNullableBool(value) {
      return value == null || value is bool;
    }

    function isNullableNumber(value) {
      return value == null || value is int || value is float;
    }

    function isNullableTimestamp(value) {
      return value == null || value is timestamp;
    }

    function isNullableList(value) {
      return value == null || value is list;
    }

    function isEmploymentType(value) {
      return value == 'full_time' ||
          value == 'part_time' ||
          value == 'internship' ||
          value == 'contract' ||
          value == 'temporary' ||
          value == 'freelance';
    }

    function isWorkMode(value) {
      return value == 'onsite' ||
          value == 'remote' ||
          value == 'hybrid';
    }

    function isSalaryPeriod(value) {
      return value == 'hour' ||
          value == 'day' ||
          value == 'week' ||
          value == 'month' ||
          value == 'year';
    }

    function hasValidOpportunityMetadata(data) {
      return (
          !data.keys().hasAny(['salaryMin']) ||
          isNullableNumber(data.salaryMin)
        ) &&
        (
          !data.keys().hasAny(['salaryMax']) ||
          isNullableNumber(data.salaryMax)
        ) &&
        (
          !data.keys().hasAny(['salaryCurrency']) ||
          isNullableString(data.salaryCurrency)
        ) &&
        (
          !data.keys().hasAny(['salaryPeriod']) ||
          data.salaryPeriod == null ||
          data.salaryPeriod == '' ||
          isSalaryPeriod(data.salaryPeriod)
        ) &&
        (
          !data.keys().hasAny(['compensationText']) ||
          isNullableString(data.compensationText)
        ) &&
        (
          !data.keys().hasAny(['employmentType']) ||
          data.employmentType == null ||
          data.employmentType == '' ||
          isEmploymentType(data.employmentType)
        ) &&
        (
          !data.keys().hasAny(['workMode']) ||
          data.workMode == null ||
          data.workMode == '' ||
          isWorkMode(data.workMode)
        ) &&
        (
          !data.keys().hasAny(['isPaid']) ||
          isNullableBool(data.isPaid)
        ) &&
        (
          !data.keys().hasAny(['duration']) ||
          isNullableString(data.duration)
        ) &&
        (
          !data.keys().hasAny(['applicationDeadline']) ||
          isNullableTimestamp(data.applicationDeadline)
        ) &&
        (
          !data.keys().hasAny(['requirementItems']) ||
          isNullableList(data.requirementItems)
        ) &&
        (
          !data.keys().hasAny(['originalLanguage']) ||
          isNullableString(data.originalLanguage)
        ) &&
        (
          !data.keys().hasAny(['fundingAmount']) ||
          isNullableNumber(data.fundingAmount)
        ) &&
        (
          !data.keys().hasAny(['fundingCurrency']) ||
          isNullableString(data.fundingCurrency)
        ) &&
        (
          !data.keys().hasAny(['fundingNote']) ||
          isNullableString(data.fundingNote)
        ) &&
        (
          !data.keys().hasAny(['updatedAt']) ||
          data.updatedAt != null
        ) &&
        (
          !data.keys().hasAll(['salaryMin', 'salaryMax']) ||
          data.salaryMin == null ||
          data.salaryMax == null ||
          data.salaryMax >= data.salaryMin
        );
    }

    function hasValidOpportunityEarlyAccessCreate(data) {
      return (
          !data.keys().hasAny([
            'earlyAccessRequested',
            'earlyAccessStatus',
            'requestedEarlyAccessAt'
          ])
        ) ||
        (
          data.keys().hasAll([
            'earlyAccessRequested',
            'earlyAccessStatus',
            'requestedEarlyAccessAt'
          ]) &&
          data.earlyAccessRequested == true &&
          isEarlyAccessStatus(data.earlyAccessStatus) &&
          data.earlyAccessStatus == 'pending' &&
          data.requestedEarlyAccessAt == request.time
        );
    }

    function canCompanyRequestEarlyAccess() {
      return isCompany() &&
          resource.data.companyId == request.auth.uid &&
          resource.data.get('earlyAccessRequested', false) != true &&
          resource.data.get('earlyAccessStatus', 'none') == 'none' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'earlyAccessRequested',
            'earlyAccessStatus',
            'requestedEarlyAccessAt',
            'updatedAt'
          ]) &&
          request.resource.data.earlyAccessRequested == true &&
          request.resource.data.earlyAccessStatus == 'pending' &&
          request.resource.data.requestedEarlyAccessAt == request.time &&
          request.resource.data.updatedAt == request.time;
    }

    function hasValidCompanyOpportunityEarlyAccessUpdate() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
            'earlyAccessRequested',
            'earlyAccessStatus',
            'requestedEarlyAccessAt'
          ]) ||
          (
            resource.data.get('earlyAccessRequested', false) != true &&
            resource.data.get('earlyAccessStatus', 'none') == 'none' &&
            request.resource.data.earlyAccessRequested == true &&
            request.resource.data.earlyAccessStatus == 'pending' &&
            request.resource.data.requestedEarlyAccessAt == request.time
          );
    }

    function canApproveEarlyAccess() {
      return resource.data.get('earlyAccessRequested', false) == true &&
          resource.data.get('earlyAccessStatus', 'none') == 'pending' &&
          request.resource.data.earlyAccessStatus == 'approved' &&
          request.resource.data.premiumEarlyAccess == true &&
          request.resource.data.earlyAccessReviewedBy == request.auth.uid &&
          request.resource.data.earlyAccessReviewedAt == request.time &&
          request.resource.data.earlyAccessDurationHours is int &&
          request.resource.data.earlyAccessDurationHours > 0 &&
          request.resource.data.publicVisibleAt is timestamp &&
          request.resource.data.publicVisibleAt > request.time;
    }

    function canRejectEarlyAccess() {
      return resource.data.get('earlyAccessRequested', false) == true &&
          resource.data.get('earlyAccessStatus', 'none') == 'pending' &&
          request.resource.data.earlyAccessStatus == 'rejected' &&
          request.resource.data.premiumEarlyAccess == false &&
          request.resource.data.earlyAccessReviewedBy == request.auth.uid &&
          request.resource.data.earlyAccessReviewedAt == request.time &&
          request.resource.data.earlyAccessRejectedReason is string;
    }

    function canRemoveEarlyAccess() {
      return request.resource.data.earlyAccessRequested == false &&
          request.resource.data.earlyAccessStatus == 'none' &&
          request.resource.data.premiumEarlyAccess == false &&
          (
            !request.resource.data.keys().hasAny(['publicVisibleAt']) ||
            request.resource.data.publicVisibleAt == null
          );
    }

    function canAdminManageEarlyAccess() {
      return isAdmin() &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'earlyAccessRequested',
            'earlyAccessStatus',
            'premiumEarlyAccess',
            'publicVisibleAt',
            'earlyAccessReviewedBy',
            'earlyAccessReviewedAt',
            'earlyAccessDurationHours',
            'earlyAccessRejectedReason',
            'updatedAt'
          ]) &&
          request.resource.data.updatedAt == request.time &&
          (
            canApproveEarlyAccess() ||
            canRejectEarlyAccess() ||
            canRemoveEarlyAccess()
          );
    }

    function isApplicationStatus(value) {
      return value == 'pending' ||
          value == 'accepted' ||
          value == 'rejected';
    }

    function hasActivePremium(uid) {
      return exists(subscriptionPath(uid)) &&
          get(subscriptionPath(uid)).data.status == 'active' &&
          get(subscriptionPath(uid)).data.expiresAt is timestamp &&
          get(subscriptionPath(uid)).data.expiresAt > request.time;
    }

    function hasValidApplicationPrioritySnapshot(data, uid) {
      return data.get('isPremiumAtApply', false) ==
          data.get('priorityApplication', false) &&
          (
            data.get('priorityApplication', false) == false ||
            hasActivePremium(uid)
          ) &&
          (
            !data.keys().hasAny(['subscriptionSnapshot']) ||
            (
              data.get('priorityApplication', false) == true &&
              data.subscriptionSnapshot is map &&
              data.subscriptionSnapshot.keys().hasOnly([
                'plan',
                'status',
                'expiresAt'
              ]) &&
              data.subscriptionSnapshot.plan ==
                  get(subscriptionPath(uid)).data.plan &&
              data.subscriptionSnapshot.status ==
                  get(subscriptionPath(uid)).data.status &&
              data.subscriptionSnapshot.expiresAt ==
                  get(subscriptionPath(uid)).data.expiresAt
            )
          );
    }

    function isProjectIdeaStatus(value) {
      return value == 'pending' ||
          value == 'approved' ||
          value == 'rejected';
    }

    function isProjectIdeaInteractionType(value) {
      return value == 'interest' ||
          value == 'save';
    }

    function isAcademicLevel(value) {
      return value == 'bac' ||
          value == 'licence' ||
          value == 'master' ||
          value == 'doctorat';
    }

    function isValidAvatarId(value) {
      return value == 'avatar_1' ||
          value == 'avatar_2' ||
          value == 'avatar_3' ||
          value == 'avatar_4' ||
          value == 'avatar_5' ||
          value == 'avatar_6' ||
          value == 'avatar_7' ||
          value == 'avatar_8';
    }

    function isStudentPhotoType(value) {
      return value == null ||
          value == '' ||
          value == 'avatar' ||
          value == 'upload';
    }

    function isCompanyPhotoType(value) {
      return value == null ||
          value == '' ||
          value == 'upload';
    }

    function hasPhotoTypeField(data) {
      return data.keys().hasAny(['photoType']);
    }

    function hasAcademicLevelField(data) {
      return data.keys().hasAny(['academicLevel']);
    }

    function hasAvatarIdField(data) {
      return data.keys().hasAny(['avatarId']);
    }

    function hasAdminLevelField(data) {
      return data.keys().hasAny(['adminLevel']);
    }

    function hasApprovalStatusField(data) {
      return data.keys().hasAny(['approvalStatus']);
    }

    function hasCreatedAtField(data) {
      return data.keys().hasAny(['createdAt']);
    }

    function hasIsActiveField(data) {
      return data.keys().hasAny(['isActive']);
    }

    function hasProfileImageField(data) {
      return data.keys().hasAny(['profileImage']);
    }

    function hasProviderField(data) {
      return data.keys().hasAny(['provider']);
    }

    function hasStudentOnboardingPendingField(data) {
      return data.keys().hasAny(['studentOnboardingPending']);
    }

    function hasLogoField(data) {
      return data.keys().hasAny(['logo']);
    }

    function isSupportedProvider(value) {
      return value == 'email' || value == 'google';
    }

    function matchesCurrentSignInProvider(value) {
      return (value == 'email' &&
              request.auth.token.firebase.sign_in_provider == 'password') ||
          (value == 'google' &&
              request.auth.token.firebase.sign_in_provider == 'google.com');
    }

    function isCompanyApprovalStatus(value) {
      return value == 'pending' ||
          value == 'approved' ||
          value == 'rejected';
    }

    function hasCompatibleAcademicLevel(newData, oldData) {
      return (
        !hasAcademicLevelField(newData) &&
        !hasAcademicLevelField(oldData)
      ) || (
        hasAcademicLevelField(newData) &&
        hasAcademicLevelField(oldData) &&
        (
          newData.academicLevel == oldData.academicLevel ||
          (oldData.role == 'student' &&
              isAcademicLevel(newData.academicLevel))
        )
      ) || (
        hasAcademicLevelField(newData) &&
        !hasAcademicLevelField(oldData) &&
        (
          newData.academicLevel == null ||
          newData.academicLevel == '' ||
          (oldData.role == 'student' &&
              isAcademicLevel(newData.academicLevel))
        )
      );
    }

    function hasCompatibleAdminLevel(newData, oldData) {
      return (
        !hasAdminLevelField(newData) &&
        !hasAdminLevelField(oldData)
      ) || (
        hasAdminLevelField(newData) &&
        hasAdminLevelField(oldData) &&
        newData.adminLevel == oldData.adminLevel
      ) || (
        hasAdminLevelField(newData) &&
        !hasAdminLevelField(oldData) &&
        newData.adminLevel == ''
      );
    }

    function hasCompatibleApprovalStatus(newData, oldData) {
      return (
        !hasApprovalStatusField(newData) &&
        !hasApprovalStatusField(oldData)
      ) || (
        hasApprovalStatusField(newData) &&
        hasApprovalStatusField(oldData) &&
        (
          newData.approvalStatus == oldData.approvalStatus ||
          (
            oldData.role == 'company' &&
            isCompanyApprovalStatus(oldData.approvalStatus) &&
            isCompanyApprovalStatus(newData.approvalStatus)
          )
        )
      ) || (
        hasApprovalStatusField(newData) &&
        !hasApprovalStatusField(oldData) &&
        (
          (
            oldData.role == 'company' &&
            isCompanyApprovalStatus(newData.approvalStatus)
          ) ||
          (
            oldData.role != 'company' &&
            newData.approvalStatus == ''
          )
        )
      );
    }

    function hasCompatibleCreatedAt(newData, oldData) {
      return (
        !hasCreatedAtField(newData) &&
        !hasCreatedAtField(oldData)
      ) || (
        hasCreatedAtField(newData) &&
        hasCreatedAtField(oldData) &&
        newData.createdAt == oldData.createdAt
      ) || (
        hasCreatedAtField(newData) &&
        !hasCreatedAtField(oldData) &&
        newData.createdAt != null
      );
    }

    function hasCompatibleIsActive(newData, oldData) {
      return (
        !hasIsActiveField(newData) &&
        !hasIsActiveField(oldData)
      ) || (
        hasIsActiveField(newData) &&
        hasIsActiveField(oldData) &&
        newData.isActive == oldData.isActive
      ) || (
        hasIsActiveField(newData) &&
        !hasIsActiveField(oldData) &&
        newData.isActive == true
      );
    }

    function hasCompatibleProvider(newData, oldData) {
      return (
        !hasProviderField(newData) &&
        !hasProviderField(oldData)
      ) || (
        hasProviderField(newData) &&
        hasProviderField(oldData) &&
        (
          newData.provider == oldData.provider ||
          (
            !isSupportedProvider(oldData.provider) &&
            isSupportedProvider(newData.provider) &&
            matchesCurrentSignInProvider(newData.provider)
          )
        )
      ) || (
        hasProviderField(newData) &&
        !hasProviderField(oldData) &&
        isSupportedProvider(newData.provider) &&
        matchesCurrentSignInProvider(newData.provider)
      );
    }

    function hasCompatibleStudentOnboardingPending(newData, oldData) {
      return (
        !hasStudentOnboardingPendingField(newData) &&
        !hasStudentOnboardingPendingField(oldData)
      ) || (
        hasStudentOnboardingPendingField(newData) &&
        hasStudentOnboardingPendingField(oldData) &&
        (
          newData.studentOnboardingPending == oldData.studentOnboardingPending ||
          (
            oldData.role == 'student' &&
            oldData.studentOnboardingPending == true &&
            newData.studentOnboardingPending == false
          )
        )
      ) || (
        hasStudentOnboardingPendingField(newData) &&
        !hasStudentOnboardingPendingField(oldData) &&
        newData.studentOnboardingPending == false
      );
    }

    function commercialRegisterFieldsChanged(newData, existingData) {
      return newData.diff(existingData).changedKeys().hasAny([
        'commercialRegisterUrl',
        'commercialRegisterFileName',
        'commercialRegisterMimeType',
        'commercialRegisterStoragePath',
        'commercialRegisterUploadedAt'
      ]);
    }

    function hasValidCommercialRegisterPayload(data) {
      return data.keys().hasAll([
          'commercialRegisterUrl',
          'commercialRegisterFileName',
          'commercialRegisterMimeType',
          'commercialRegisterStoragePath',
          'commercialRegisterUploadedAt'
        ]) &&
        data.commercialRegisterUrl is string &&
        data.commercialRegisterUrl.size() > 0 &&
        data.commercialRegisterFileName is string &&
        data.commercialRegisterFileName.size() > 0 &&
        data.commercialRegisterStoragePath is string &&
        data.commercialRegisterStoragePath.size() > 0 &&
        isCommercialRegisterMimeType(
          data.commercialRegisterMimeType
        ) &&
        data.commercialRegisterUploadedAt != null;
    }

    function hasValidProfilePhotoFields(data, role) {
      return role == 'student'
          ? (
              (
                !hasPhotoTypeField(data) ||
                isStudentPhotoType(data.photoType)
              ) &&
              (
                !hasPhotoTypeField(data) ||
                data.photoType != 'avatar' ||
                (
                  hasAvatarIdField(data) &&
                  isValidAvatarId(data.avatarId)
                )
              ) &&
              (
                !hasPhotoTypeField(data) ||
                data.photoType == 'avatar' ||
                !hasAvatarIdField(data) ||
                data.avatarId == null ||
                data.avatarId == ''
              ) &&
              (
                !hasPhotoTypeField(data) ||
                data.photoType != 'upload' ||
                (
                  hasProfileImageField(data) &&
                  data.profileImage is string &&
                  data.profileImage.size() > 0
                )
              )
            )
          : role == 'company'
          ? (
              (
                !hasPhotoTypeField(data) ||
                isCompanyPhotoType(data.photoType)
              ) &&
              (
                !hasAvatarIdField(data) ||
                data.avatarId == null ||
                data.avatarId == ''
              ) &&
              (
                !hasPhotoTypeField(data) ||
                data.photoType != 'upload' ||
                (
                  hasLogoField(data) &&
                  data.logo is string &&
                  data.logo.size() > 0
                )
              )
            )
          : (
              (
                !hasPhotoTypeField(data) ||
                data.photoType == null ||
                data.photoType == ''
              ) &&
              (
                !hasAvatarIdField(data) ||
                data.avatarId == null ||
                data.avatarId == ''
              )
            );
    }

    function isCommercialRegisterMimeType(value) {
      return value == 'application/pdf' ||
          value == 'image/png' ||
          value == 'image/jpeg';
    }

    function isConversationStatus(value) {
      return value == 'active' || value == 'closed';
    }

    function isMessageType(value) {
      return value == 'text' || value == 'image' || value == 'file';
    }

    function isParticipant(conversationId) {
      return signedIn() &&
          exists(conversationPath(conversationId)) &&
          (get(conversationPath(conversationId)).data.studentId == request.auth.uid ||
              get(conversationPath(conversationId)).data.companyId == request.auth.uid);
    }

    function hasLinkedApplication(data) {
      return data.keys().hasAll(['applicationId']) &&
          data.applicationId is string &&
          data.applicationId.size() > 0 &&
          exists(applicationPath(data.applicationId)) &&
          get(applicationPath(data.applicationId)).data.studentId == data.studentId &&
          get(applicationPath(data.applicationId)).data.companyId == data.companyId;
    }

    function linkedApplicationStatus(data) {
      return get(applicationPath(data.applicationId)).data.status;
    }

    function isConversationCreator(data) {
      return data.get('createdById', '') == request.auth.uid &&
          (
            (
              isStudent() &&
              data.get('createdByRole', '') == 'student' &&
              data.studentId == request.auth.uid
            ) ||
            (
              isCompany() &&
              data.get('createdByRole', '') == 'company' &&
              data.companyId == request.auth.uid
            )
          );
    }

    function canCreateApplicationConversation(data) {
      return hasLinkedApplication(data) &&
          isConversationCreator(data) &&
          data.companyHasMessaged == false &&
          (
            (
              isStudent() &&
              data.studentId == request.auth.uid &&
              linkedApplicationStatus(data) == 'accepted'
            ) ||
            (
              isCompany() &&
              data.companyId == request.auth.uid
            )
          );
    }

    function hasCompatibleConversationMessagingFlag() {
      return request.resource.data.get('companyHasMessaged', false) ==
          resource.data.get('companyHasMessaged', false) ||
          (
            isCompany() &&
            resource.data.companyId == request.auth.uid &&
            resource.data.get('companyHasMessaged', false) == false &&
            request.resource.data.get('companyHasMessaged', false) == true
          );
    }

    function canSendApplicationMessage(conversationId) {
      let conversation = get(conversationPath(conversationId)).data;
      return hasLinkedApplication(conversation) &&
          (
            (
              isCompany() &&
              conversation.companyId == request.auth.uid
            ) ||
            (
              isStudent() &&
              conversation.studentId == request.auth.uid &&
              (
                linkedApplicationStatus(conversation) == 'accepted' ||
                conversation.get('companyHasMessaged', false) == true
              )
            )
          );
    }

    match /users/{uid} {
      allow create: if isSelf(uid) &&
          request.resource.data.keys().hasOnly([
            'uid',
            'fullName',
            'email',
            'role',
            'academicLevel',
            'phone',
            'location',
            'profileImage',
            'photoType',
            'avatarId',
            'university',
            'fieldOfStudy',
            'bio',
            'companyName',
            'sector',
            'description',
            'website',
            'logo',
            'adminLevel',
            'researchTopic',
            'laboratory',
            'supervisor',
            'researchDomain',
            'commercialRegisterUrl',
            'commercialRegisterFileName',
            'commercialRegisterMimeType',
            'commercialRegisterStoragePath',
            'commercialRegisterUploadedAt',
            'approvalStatus',
            'isOnline',
            'lastSeenAt',
            'isActive',
            'createdAt',
            'provider',
            'studentOnboardingPending'
          ]) &&
          request.resource.data.uid == uid &&
          request.resource.data.email == request.auth.token.email &&
          (request.resource.data.role == 'student' ||
              request.resource.data.role == 'company') &&
          (request.resource.data.provider == 'email' ||
              request.resource.data.provider == 'google') &&
          request.resource.data.studentOnboardingPending is bool &&
          (
            request.resource.data.role == 'student' ||
            request.resource.data.studentOnboardingPending == false
          ) &&
          (
            request.resource.data.provider == 'google' ||
            request.resource.data.studentOnboardingPending == false
          ) &&
          (
            request.resource.data.role == 'student' ||
            (
              request.resource.data.commercialRegisterUrl is string &&
              request.resource.data.commercialRegisterUrl.size() > 0 &&
              request.resource.data.commercialRegisterFileName is string &&
              request.resource.data.commercialRegisterFileName.size() > 0 &&
              request.resource.data.commercialRegisterStoragePath is string &&
              request.resource.data.commercialRegisterStoragePath.size() > 0 &&
              isCommercialRegisterMimeType(
                request.resource.data.commercialRegisterMimeType
              ) &&
              request.resource.data.commercialRegisterUploadedAt != null
            )
          ) &&
          hasValidProfilePhotoFields(
            request.resource.data,
            request.resource.data.role
          ) &&
          (request.resource.data.academicLevel == null ||
              request.resource.data.academicLevel == '' ||
              isAcademicLevel(request.resource.data.academicLevel)) &&
          request.resource.data.adminLevel == '' &&
          (
            request.resource.data.role == 'company'
                ? request.resource.data.approvalStatus == 'pending'
                : request.resource.data.approvalStatus == ''
          ) &&
          request.resource.data.isActive == true;

      allow read: if signedIn() && (isSelf(uid) || isAdmin());

      allow update: if signedIn() && (
          (
            isSelf(uid) &&
            request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'fullName',
              'phone',
              'location',
              'profileImage',
              'photoType',
              'avatarId',
              'university',
              'fieldOfStudy',
              'bio',
              'companyName',
              'sector',
              'description',
              'website',
              'logo',
              'academicLevel',
              'commercialRegisterUrl',
              'commercialRegisterFileName',
              'commercialRegisterMimeType',
              'commercialRegisterStoragePath',
              'commercialRegisterUploadedAt',
              'isOnline',
              'lastSeenAt',
              'fcmToken',
              'fcmTokenUpdatedAt',
              'fcmTokenPlatform',
              'studentOnboardingPending'
            ]) &&
            request.resource.data.uid == resource.data.uid &&
            request.resource.data.email == resource.data.email &&
            request.resource.data.role == resource.data.role &&
            hasCompatibleAcademicLevel(
              request.resource.data,
              resource.data
            ) &&
            hasValidProfilePhotoFields(
              request.resource.data,
              resource.data.role
            ) &&
            hasCompatibleAdminLevel(
              request.resource.data,
              resource.data
            ) &&
            hasCompatibleApprovalStatus(
              request.resource.data,
              resource.data
            ) &&
            hasCompatibleIsActive(
              request.resource.data,
              resource.data
            ) &&
            hasCompatibleCreatedAt(
              request.resource.data,
              resource.data
            ) &&
            hasCompatibleProvider(
              request.resource.data,
              resource.data
            ) &&
            hasCompatibleStudentOnboardingPending(
              request.resource.data,
              resource.data
            ) &&
            (
              resource.data.role != 'company'
              ? !commercialRegisterFieldsChanged(
                  request.resource.data,
                  resource.data
                )
              : (
                  !commercialRegisterFieldsChanged(
                    request.resource.data,
                    resource.data
                  ) ||
                  hasValidCommercialRegisterPayload(request.resource.data)
                )
            )
          ) ||
          (
            isAdmin() &&
            request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'isActive',
              'approvalStatus'
            ]) &&
            request.resource.data.uid == resource.data.uid &&
            request.resource.data.email == resource.data.email &&
            request.resource.data.role == resource.data.role &&
            hasCompatibleAcademicLevel(
              request.resource.data,
              resource.data
            ) &&
            hasCompatibleAdminLevel(
              request.resource.data,
              resource.data
            ) &&
            hasCompatibleApprovalStatus(
              request.resource.data,
              resource.data
            ) &&
            hasCompatibleCreatedAt(
              request.resource.data,
              resource.data
            ) &&
            hasCompatibleProvider(
              request.resource.data,
              resource.data
            ) &&
            hasCompatibleStudentOnboardingPending(
              request.resource.data,
              resource.data
            )
          )
        );

      allow delete: if isAdmin();

      match /saved_trainings/{trainingId} {
        allow read: if signedIn() && (isSelf(uid) || isAdmin());

        allow create, update: if isStudent() &&
            isSelf(uid) &&
            request.resource.data.keys().hasOnly([
              'id',
              'trainingId',
              'title',
              'description',
              'provider',
              'providerLogo',
              'duration',
              'level',
              'link',
              'type',
              'source',
              'authors',
              'thumbnail',
              'domain',
              'language',
              'previewLink',
              'isApproved',
              'isFeatured',
              'rating',
              'learnerCount',
              'learnerCountLabel',
              'isFree',
              'hasCertificate',
              'savedAt'
            ]) &&
            request.resource.data.id == trainingId &&
            request.resource.data.trainingId == trainingId &&
            exists(trainingPath(trainingId));

        allow delete: if isAdmin() ||
            (isStudent() && isSelf(uid));
      }
