    match /savedOpportunities/{savedId} {
      allow read: if signedIn() &&
          (isAdmin() || resource.data.studentId == request.auth.uid);

      allow create: if isStudent() &&
          request.resource.data.keys().hasOnly([
            'id',
            'opportunityId',
            'studentId',
            'title',
            'companyName',
            'type',
            'location',
            'deadline',
            'fundingLabel',
            'savedAt'
          ]) &&
          request.resource.data.id == savedId &&
          request.resource.data.studentId == request.auth.uid &&
          canStudentUseOpportunity(request.resource.data.opportunityId);

      allow update: if false;

      allow delete: if isAdmin() ||
          (isStudent() && resource.data.studentId == request.auth.uid);
    }

    match /savedScholarships/{savedId} {
      allow read: if signedIn() &&
          (isAdmin() || resource.data.studentId == request.auth.uid);

      allow create: if isStudent() &&
          request.resource.data.keys().hasOnly([
            'id',
            'scholarshipId',
            'studentId',
            'title',
            'provider',
            'deadline',
            'location',
            'fundingType',
            'level',
            'savedAt'
          ]) &&
          request.resource.data.id == savedId &&
          request.resource.data.studentId == request.auth.uid &&
          exists(scholarshipPath(request.resource.data.scholarshipId));

      allow update: if false;

      allow delete: if isAdmin() ||
          (isStudent() && resource.data.studentId == request.auth.uid);
    }

    match /projectIdeas/{ideaId} {
      allow read: if isAdmin()
          || (signedIn() && resource.data.submittedBy == request.auth.uid)
          || (
            signedIn() &&
            resource.data.status == 'approved' &&
            resource.data.get('isHidden', false) != true
          );

      allow create: if (isStudent() || isAdmin()) &&
          request.resource.data.keys().hasOnly([
            'id',
            'title',
            'description',
            'domain',
            'level',
            'tools',
            'originalLanguage',
            'tagline',
            'shortDescription',
            'category',
            'tags',
            'stage',
            'skillsNeeded',
            'teamNeeded',
            'targetAudience',
            'problemStatement',
            'solution',
            'resourcesNeeded',
            'benefits',
            'imageUrl',
            'attachmentUrl',
            'isPublic',
            'isHidden',
            'submittedByName',
            'authorAvatar',
            'authorPhotoType',
            'authorAvatarId',
            'status',
            'submittedBy',
            'createdAt',
            'updatedAt'
          ]) &&
          request.resource.data.id == ideaId &&
          request.resource.data.submittedBy == request.auth.uid &&
          (
            (
              isStudent() &&
              request.resource.data.status == 'pending'
            ) ||
            (
              isAdmin() &&
              (
                request.resource.data.status == 'approved' ||
                request.resource.data.status == 'rejected'
              )
            )
          ) &&
          isAcademicLevel(request.resource.data.level);

      allow update: if (
          // Admin can change status only
          isAdmin() &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'status'
          ]) &&
          request.resource.data.id == resource.data.id &&
          request.resource.data.title == resource.data.title &&
          request.resource.data.description == resource.data.description &&
          request.resource.data.domain == resource.data.domain &&
          request.resource.data.level == resource.data.level &&
          request.resource.data.tools == resource.data.tools &&
          request.resource.data.submittedBy == resource.data.submittedBy &&
          request.resource.data.createdAt == resource.data.createdAt &&
          isProjectIdeaStatus(request.resource.data.status)
        ) || (
          // Admin can hide or restore ideas without changing the content
          isAdmin() &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'isHidden',
            'updatedAt'
          ]) &&
          request.resource.data.id == resource.data.id &&
          request.resource.data.title == resource.data.title &&
          request.resource.data.description == resource.data.description &&
          request.resource.data.domain == resource.data.domain &&
          request.resource.data.level == resource.data.level &&
          request.resource.data.tools == resource.data.tools &&
          request.resource.data.status == resource.data.status &&
          request.resource.data.submittedBy == resource.data.submittedBy &&
          request.resource.data.createdAt == resource.data.createdAt
        ) || (
          // Admin can edit ideas they created
          isAdmin() &&
          resource.data.submittedBy == request.auth.uid &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'title',
            'description',
            'domain',
            'level',
            'tools',
            'originalLanguage',
            'tagline',
            'shortDescription',
            'category',
            'tags',
            'stage',
            'skillsNeeded',
            'teamNeeded',
            'targetAudience',
            'problemStatement',
            'solution',
            'resourcesNeeded',
            'benefits',
            'imageUrl',
            'attachmentUrl',
            'isPublic',
            'isHidden',
            'status',
            'updatedAt'
          ]) &&
          request.resource.data.id == resource.data.id &&
          request.resource.data.submittedBy == resource.data.submittedBy &&
          request.resource.data.createdAt == resource.data.createdAt &&
          isProjectIdeaStatus(request.resource.data.status) &&
          isAcademicLevel(request.resource.data.level)
        ) || (
          // Owner can edit content fields while idea is still pending
          isStudent() &&
          resource.data.submittedBy == request.auth.uid &&
          resource.data.status == 'pending' &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'title',
            'description',
            'domain',
            'level',
            'tools',
            'originalLanguage',
            'tagline',
            'shortDescription',
            'category',
            'tags',
            'stage',
            'skillsNeeded',
            'teamNeeded',
            'targetAudience',
            'problemStatement',
            'solution',
            'resourcesNeeded',
            'benefits',
            'imageUrl',
            'attachmentUrl',
            'isPublic',
            'updatedAt'
          ]) &&
          request.resource.data.id == resource.data.id &&
          request.resource.data.status == resource.data.status &&
          request.resource.data.submittedBy == resource.data.submittedBy &&
          request.resource.data.createdAt == resource.data.createdAt &&
          isAcademicLevel(request.resource.data.level)
        ) || (
          // Owner can revise rejected or hidden ideas and resubmit them
          isStudent() &&
          resource.data.submittedBy == request.auth.uid &&
          (
            resource.data.status == 'rejected' ||
            resource.data.get('isHidden', false) == true
          ) &&
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'title',
            'description',
            'domain',
            'level',
            'tools',
            'originalLanguage',
            'tagline',
            'shortDescription',
            'category',
            'tags',
            'stage',
            'skillsNeeded',
            'teamNeeded',
            'targetAudience',
            'problemStatement',
            'solution',
            'resourcesNeeded',
            'benefits',
            'imageUrl',
            'attachmentUrl',
            'isPublic',
            'isHidden',
            'status',
            'updatedAt'
          ]) &&
          request.resource.data.id == resource.data.id &&
          request.resource.data.status == 'pending' &&
          request.resource.data.get('isHidden', false) == false &&
          request.resource.data.submittedBy == resource.data.submittedBy &&
          request.resource.data.createdAt == resource.data.createdAt &&
          isAcademicLevel(request.resource.data.level)
        );

      allow delete: if isAdmin() ||
          (
            signedIn() &&
            resource.data.submittedBy == request.auth.uid
          );
    }

    match /projectIdeaInteractions/{interactionId} {
      allow read: if signedIn() &&
          (
            isAdmin() ||
            (
              exists(projectIdeaPath(resource.data.ideaId)) &&
              (
                (
                  get(projectIdeaPath(resource.data.ideaId)).data.status == 'approved' &&
                  get(projectIdeaPath(resource.data.ideaId)).data.get('isHidden', false) != true
                ) ||
                get(projectIdeaPath(resource.data.ideaId)).data.submittedBy == request.auth.uid
              )
            )
          );

      allow create: if isStudent() &&
          request.resource.data.keys().hasOnly([
            'id',
            'ideaId',
            'userId',
            'type',
            'createdAt'
          ]) &&
          request.resource.data.id == interactionId &&
          request.resource.data.userId == request.auth.uid &&
          isProjectIdeaInteractionType(request.resource.data.type) &&
          exists(projectIdeaPath(request.resource.data.ideaId)) &&
          (
            (
              get(projectIdeaPath(request.resource.data.ideaId)).data.status == 'approved' &&
              get(projectIdeaPath(request.resource.data.ideaId)).data.get('isHidden', false) != true
            ) ||
            get(projectIdeaPath(request.resource.data.ideaId)).data.submittedBy == request.auth.uid
          );

      allow update: if false;

      allow delete: if isAdmin() ||
          (isStudent() && resource.data.userId == request.auth.uid);
    }

    match /scholarships/{scholarshipId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /trainings/{trainingId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /adminActivityEvents/{eventId} {
      allow read: if isAdmin();

      allow create: if isAdmin() &&
          request.resource.data.keys().hasOnly([
            'id',
            'type',
            'action',
            'targetCollection',
            'targetId',
            'title',
            'description',
            'actorId',
            'actorName',
            'subjectId',
            'subjectName',
            'status',
            'metadata',
            'createdAt'
          ]) &&
          request.resource.data.id == eventId &&
          request.resource.data.type in [
            'application',
            'opportunity',
            'scholarship',
            'training',
            'project_idea',
            'user'
          ] &&
          request.resource.data.action is string &&
          request.resource.data.targetCollection is string &&
          request.resource.data.targetId is string &&
          request.resource.data.title is string &&
          request.resource.data.description is string &&
          request.resource.data.actorId == request.auth.uid &&
          request.resource.data.actorName is string &&
          request.resource.data.subjectId is string &&
          request.resource.data.subjectName is string &&
          request.resource.data.status is string &&
          request.resource.data.metadata is map &&
          request.resource.data.createdAt == request.time;

      allow update, delete: if false;
    }

    match /notifications/{notificationId} {
      allow read: if signedIn() &&
          (isAdmin() || resource.data.userId == request.auth.uid);

      allow create: if signedIn() &&
          (isAdmin() || isStudent() || isCompany()) &&
          request.resource.data.keys().hasOnly([
            'id',
            'userId',
            'title',
            'message',
            'type',
            'createdAt',
            'isRead',
            'conversationId',
            'targetId'
          ]) &&
          request.resource.data.id == notificationId &&
          request.resource.data.userId != request.auth.uid &&
          request.resource.data.isRead == false &&
          (
            (
              request.resource.data.type == 'chat' &&
              request.resource.data.conversationId is string &&
              request.resource.data.conversationId.size() > 0 &&
              isParticipant(request.resource.data.conversationId) &&
              (
                get(conversationPath(request.resource.data.conversationId)).data.studentId == request.resource.data.userId ||
                get(conversationPath(request.resource.data.conversationId)).data.companyId == request.resource.data.userId
              )
            )
            ||
            (
              request.resource.data.type == 'application' &&
              isCompany()
            )
            ||
            (
              request.resource.data.type in ['opportunity', 'scholarship', 'training'] &&
              isCompany()
            )
          );

      allow delete: if isAdmin();

      allow update: if isAdmin() ||
          (
            signedIn() &&
            resource.data.userId == request.auth.uid &&
            request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'isRead'
            ]) &&
            request.resource.data.id == resource.data.id &&
            request.resource.data.userId == resource.data.userId &&
            request.resource.data.title == resource.data.title &&
            request.resource.data.message == resource.data.message &&
            request.resource.data.type == resource.data.type &&
            request.resource.data.createdAt == resource.data.createdAt &&
            request.resource.data.conversationId == resource.data.conversationId
          );
    }

    match /conversations/{conversationId} {
      allow read: if isAdmin() ||
          (signedIn() &&
              (resource.data.studentId == request.auth.uid ||
                  resource.data.companyId == request.auth.uid));

      allow create: if signedIn() &&
          request.resource.data.keys().hasOnly([
            'id',
            'studentId',
            'studentName',
            'companyId',
            'companyName',
            'lastMessage',
            'lastMessageType',
            'lastMessageSenderId',
            'lastMessageSenderName',
            'lastMessageTime',
            'startedAt',
            'status',
            'studentUnreadCount',
            'companyUnreadCount',
            'archivedBy',
            'mutedBy',
            'deletedBy',
            'contextType',
            'contextLabel',
            'applicationId',
            'createdById',
            'createdByRole',
            'companyHasMessaged',
            'isGroup',
            'groupName',
            'groupAvatarUrl'
          ]) &&
          request.resource.data.id == conversationId &&
          (
            (isStudent() && request.resource.data.studentId == request.auth.uid) ||
            (isCompany() && request.resource.data.companyId == request.auth.uid)
          ) &&
          isConversationStatus(request.resource.data.status) &&
          request.resource.data.companyHasMessaged is bool &&
          canCreateApplicationConversation(request.resource.data);

      allow update: if isAdmin() ||
          (
            signedIn() &&
            (resource.data.studentId == request.auth.uid ||
                resource.data.companyId == request.auth.uid) &&
            request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'lastMessage',
              'lastMessageType',
              'lastMessageSenderId',
              'lastMessageSenderName',
              'lastMessageTime',
              'status',
              'studentUnreadCount',
              'companyUnreadCount',
              'archivedBy',
              'mutedBy',
              'deletedBy',
              'contextType',
              'contextLabel',
              'applicationId',
              'companyHasMessaged'
            ]) &&
            request.resource.data.id == resource.data.id &&
            request.resource.data.studentId == resource.data.studentId &&
            request.resource.data.studentName == resource.data.studentName &&
            request.resource.data.companyId == resource.data.companyId &&
            request.resource.data.companyName == resource.data.companyName &&
            request.resource.data.get('createdById', '') == resource.data.get('createdById', '') &&
            request.resource.data.get('createdByRole', '') == resource.data.get('createdByRole', '') &&
            request.resource.data.get('startedAt', null) == resource.data.get('startedAt', null) &&
            request.resource.data.get('isGroup', null) == resource.data.get('isGroup', null) &&
            request.resource.data.get('groupName', null) == resource.data.get('groupName', null) &&
            request.resource.data.get('groupAvatarUrl', null) == resource.data.get('groupAvatarUrl', null) &&
            isConversationStatus(request.resource.data.get('status', 'active')) &&
            hasLinkedApplication(request.resource.data) &&
            hasCompatibleConversationMessagingFlag()
          );

      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isAdmin() || isParticipant(conversationId);

        allow create: if isParticipant(conversationId) &&
            request.resource.data.keys().hasOnly([
              'id',
              'senderId',
              'senderRole',
              'text',
              'messageType',
              'attachmentUrl',
              'attachmentStoragePath',
              'fileName',
              'fileSize',
              'mimeType',
              'thumbnailUrl',
              'sentAt',
              'deliveredAt',
              'seenAt',
              'isRead',
              'isEdited',
              'isDeleted',
              'editedAt'
            ]) &&
            request.resource.data.id == messageId &&
            request.resource.data.senderId == request.auth.uid &&
            request.resource.data.isEdited == false &&
            request.resource.data.isDeleted == false &&
            isMessageType(request.resource.data.messageType) &&
            (
              (isStudent() && request.resource.data.senderRole == 'student') ||
              (isCompany() && request.resource.data.senderRole == 'company')
            ) &&
            canSendApplicationMessage(conversationId);

        allow update: if isAdmin() ||
            (
              isParticipant(conversationId) &&
              resource.data.senderId != request.auth.uid &&
              request.resource.data.diff(resource.data).changedKeys().hasOnly([
                'isRead',
                'seenAt'
              ]) &&
              request.resource.data.id == resource.data.id &&
              request.resource.data.senderId == resource.data.senderId &&
              request.resource.data.get('senderRole', null) == resource.data.get('senderRole', null) &&
              request.resource.data.get('text', '') == resource.data.get('text', '') &&
              request.resource.data.get('messageType', 'text') == resource.data.get('messageType', 'text') &&
              request.resource.data.get('attachmentUrl', '') == resource.data.get('attachmentUrl', '') &&
              request.resource.data.get('attachmentStoragePath', '') == resource.data.get('attachmentStoragePath', '') &&
              request.resource.data.get('fileName', '') == resource.data.get('fileName', '') &&
              request.resource.data.get('fileSize', 0) == resource.data.get('fileSize', 0) &&
              request.resource.data.get('mimeType', '') == resource.data.get('mimeType', '') &&
              request.resource.data.get('thumbnailUrl', '') == resource.data.get('thumbnailUrl', '') &&
              request.resource.data.sentAt == resource.data.sentAt &&
              request.resource.data.get('deliveredAt', null) == resource.data.get('deliveredAt', null) &&
              request.resource.data.get('isEdited', false) == resource.data.get('isEdited', false) &&
              request.resource.data.get('isDeleted', false) == resource.data.get('isDeleted', false) &&
              request.resource.data.get('editedAt', null) == resource.data.get('editedAt', null)
            ) ||
            (
              isParticipant(conversationId) &&
              resource.data.senderId == request.auth.uid &&
              resource.data.get('isDeleted', false) == false &&
              request.resource.data.diff(resource.data).changedKeys().hasOnly([
                'text',
                'isEdited',
                'editedAt'
              ]) &&
              request.resource.data.isEdited == true &&
              request.resource.data.id == resource.data.id &&
              request.resource.data.senderId == resource.data.senderId &&
              request.resource.data.get('senderRole', null) == resource.data.get('senderRole', null) &&
              request.resource.data.get('messageType', 'text') == resource.data.get('messageType', 'text') &&
              request.resource.data.get('attachmentUrl', '') == resource.data.get('attachmentUrl', '') &&
              request.resource.data.get('attachmentStoragePath', '') == resource.data.get('attachmentStoragePath', '') &&
              request.resource.data.get('fileName', '') == resource.data.get('fileName', '') &&
              request.resource.data.get('fileSize', 0) == resource.data.get('fileSize', 0) &&
              request.resource.data.get('mimeType', '') == resource.data.get('mimeType', '') &&
              request.resource.data.get('thumbnailUrl', '') == resource.data.get('thumbnailUrl', '') &&
              request.resource.data.sentAt == resource.data.sentAt &&
              request.resource.data.get('deliveredAt', null) == resource.data.get('deliveredAt', null) &&
              request.resource.data.get('seenAt', null) == resource.data.get('seenAt', null) &&
              request.resource.data.get('isRead', false) == resource.data.get('isRead', false) &&
              request.resource.data.get('isDeleted', false) == resource.data.get('isDeleted', false)
            ) ||
            (
              isParticipant(conversationId) &&
              resource.data.senderId == request.auth.uid &&
              resource.data.get('isDeleted', false) == false &&
              request.resource.data.diff(resource.data).changedKeys().hasOnly([
                'isDeleted',
                'text'
              ]) &&
              request.resource.data.isDeleted == true &&
              request.resource.data.text == '' &&
              request.resource.data.id == resource.data.id &&
              request.resource.data.senderId == resource.data.senderId &&
              request.resource.data.get('senderRole', null) == resource.data.get('senderRole', null) &&
              request.resource.data.get('messageType', 'text') == resource.data.get('messageType', 'text') &&
              request.resource.data.get('attachmentUrl', '') == resource.data.get('attachmentUrl', '') &&
              request.resource.data.get('attachmentStoragePath', '') == resource.data.get('attachmentStoragePath', '') &&
              request.resource.data.get('fileName', '') == resource.data.get('fileName', '') &&
              request.resource.data.get('fileSize', 0) == resource.data.get('fileSize', 0) &&
              request.resource.data.get('mimeType', '') == resource.data.get('mimeType', '') &&
              request.resource.data.get('thumbnailUrl', '') == resource.data.get('thumbnailUrl', '') &&
              request.resource.data.sentAt == resource.data.sentAt &&
              request.resource.data.get('deliveredAt', null) == resource.data.get('deliveredAt', null) &&
              request.resource.data.get('seenAt', null) == resource.data.get('seenAt', null) &&
              request.resource.data.get('isRead', false) == resource.data.get('isRead', false)
            );

        allow delete: if isAdmin();
      }
    }

    // ── subscriptions ─────────────────────────────────────────────────────
    // Only the Cloudflare Worker (Firebase Admin SDK) may write subscriptions.
    // Students can read their own document; admins can read all.
    match /subscriptions/{uid} {
      allow read: if isSelf(uid) || isAdmin();
      allow write: if false; // Worker writes via Admin SDK, bypassing rules
    }

    // ── payments ──────────────────────────────────────────────────────────
    // Only Worker (Admin SDK) writes. Students read their own; admins read all.
    match /payments/{paymentId} {
      allow read: if isAdmin() ||
        (isStudent() && resource.data.uid == request.auth.uid);
      allow write: if false;
    }

    // ── appConfig ─────────────────────────────────────────────────────────
    // Public read for premium config; only admin may write.
    match /appConfig/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // ── opportunities (early access extension) ────────────────────────────
    match /opportunities/{opportunityId} {
      allow update: if canCompanyRequestEarlyAccess() ||
          canAdminManageEarlyAccess();
    }
  }
}
