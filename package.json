{
  "$schema": "./.vscode/schemas/package.schema.json",
  "name": "futuregate",
  "version": "2.0.0",
  "description": "FutureGate — connect students with opportunities, scholarships, and internships.",
  "main": "index.js",
  "directories": {
    "lib": "lib",
    "test": "test"
  },
  "scripts": {
    "seed:firebase": "node firebase_seed/seed.js",
    "seed:firebase:admin": "node firebase_seed/seed.js --admin-only",
    "admin:add": "node tools/add_admin.js",
    "clear:notifications": "node firebase_seed/clear_notifications.js",
    "test": "node -e \"console.log('No root Node tests configured. Run npm run verify:flutter for the Flutter checks.')\"",
    "verify:flutter": "flutter analyze && flutter test",
    "build:web": "flutter build web",
    "deploy:hosting:root": "firebase deploy --only hosting:root",
    "deploy:hosting:admin": "firebase deploy --only hosting:admin",
    "deploy:hosting:all": "firebase deploy --only hosting"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "firebase-admin": "^13.7.0"
  },
  "devDependencies": {
    "wrangler": "^4.78.0"
  }
}
